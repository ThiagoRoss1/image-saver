{
    "manifest_version": 3,
    "name": "Image Saver",
    "version": "1.0.0",
    "description": "A Chrome extension to save images from the web.",
    "permissions": [
        "activeTab",
        "scripting",
        "contextMenus",
        "downloads",
        "offscreen"
    ],
    "host_permissions": ["<all_urls>"],
    "action": {
        "default_popup": "index.html"
    },
    "icons": {
        "16": "icons/godrinking.png",
        "48": "icons/godrinking.png",
        "128": "icons/godrinking.png"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    }
}